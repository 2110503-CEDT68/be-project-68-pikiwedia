              "future.setDate(future.getDate() + 3);",
              "pm.collectionVariables.set('reserve_date', future.toISOString());"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201 Created\", function () {",

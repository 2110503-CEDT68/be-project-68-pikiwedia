              "const json = pm.response.json();",
              "",
              "pm.test(\"success is true\", function () {",
              "    pm.expect(json.success).to.be.true;",
              "});",
              "",
              "pm.test(\"Returns an array of shops\", function () {",
              "    pm.expect(json.data).to.be.an('array').and.not.empty;",
              "});",
              "",
              "pm.test(\"Each shop has required fields\", function () {",
              "    const shop = json.data[0];",
              "    pm.expect(shop).to.have.property('name');",
              "    pm.expect(shop).to.have.property('province');",
              "    pm.expect(shop).to.have.property('price');",
              "});",
              "",
              "pm.collectionVariables.set('massage_id', json.data[0]._id);"
            ],
            "type": "text/javascript"
          }
        }
